{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "raci.schema.json",
  "title": "CMMC Information Security Responsibility Matrix",
  "description": "v0.2.0 — Primary/Backup model with access methods, frequency, and tool descriptions",
  "type": "object",
  "required": ["schema_version", "id", "client", "version", "last_updated", "roles", "assignments"],
  "properties": {
    "schema_version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "id": { "type": "string" },
    "client": { "type": "string", "minLength": 1 },
    "version": { "type": "string" },
    "last_updated": { "type": "string", "format": "date-time" },
    "roles": { "type": "array", "items": { "$ref": "#/$defs/Role" } },
    "assignments": { "type": "array", "items": { "$ref": "#/$defs/Assignment" } }
  },
  "$defs": {
    "Role": {
      "type": "object",
      "required": ["id", "title", "department"],
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "department": { "type": "string" },
        "person_name": { "type": ["string", "null"] },
        "person_email": { "type": ["string", "null"] },
        "person_title": { "type": ["string", "null"] }
      }
    },
    "Assignment": {
      "type": "object",
      "required": ["capability_id", "primary_role_id"],
      "properties": {
        "capability_id": { "type": "string" },
        "primary_role_id": { "type": "string" },
        "backup_role_id": { "type": ["string", "null"] },
        "tool_description": { "type": ["string", "null"] },
        "access_methods": {
          "type": "array",
          "items": { "type": "string", "enum": ["VPN", "ON-PREM", "VDI", "CLOUD"] }
        },
        "frequency": {
          "type": ["string", "null"],
          "enum": ["Daily", "Weekly", "Monthly", "Quarterly", "Annually", "As Needed", "24/7 On-Call", null]
        },
        "notes": { "type": ["string", "null"] }
      }
    }
  }
}
